<!DOCTYPE html>
<html>
<head>
<style>
html { background: #ffffff; }
body {
  width: 720pt; height: 405pt; margin: 0; padding: 0;
  background: #F4F6F6;
  font-family: Arial, sans-serif;
  display: flex;
}
.header {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 70pt;
  background: #2E4053;
  display: flex;
  align-items: center;
  padding-left: 40pt;
}
.header h1 {
  color: #FFFFFF;
  font-size: 28pt;
  margin: 0;
  font-weight: bold;
}
.content {
  margin-top: 90pt;
  margin-left: 50pt;
  margin-right: 50pt;
}
.main-box {
  background: #FFFFFF;
  border-left: 6pt solid #E67E22;
  padding: 30pt 40pt;
  border-radius: 4pt;
}
.title {
  color: #E67E22;
  font-size: 24pt;
  font-weight: bold;
  margin: 0 0 25pt 0;
}
.section {
  margin: 20pt 0;
}
.section-label {
  color: #2E4053;
  font-size: 16pt;
  font-weight: bold;
  margin: 0 0 10pt 0;
}
.app-list {
  margin: 0;
  padding-left: 20pt;
}
.app-list li {
  color: #2C3E50;
  font-size: 16pt;
  margin: 8pt 0;
}
.feature-list {
  margin: 0;
  padding-left: 20pt;
}
.feature-list li {
  color: #27AE60;
  font-size: 16pt;
  margin: 8pt 0;
}
</style>
</head>
<body>
<div class="header">
  <h1>工业条码打印机</h1>
</div>
<div class="content">
  <div class="main-box">
    <p class="title">工业4寸（热转印）</p>
    <div class="section">
      <p class="section-label">应用场景</p>
      <ul class="app-list">
        <li>工业条码</li>
        <li>产品流水标贴</li>
      </ul>
    </div>
    <div class="section">
      <p class="section-label">产品特点</p>
      <ul class="feature-list">
        <li>高耐用性</li>
        <li>大批量生产</li>
        <li>工业级稳定性</li>
      </ul>
    </div>
  </div>
</div>
</body>
</html>
