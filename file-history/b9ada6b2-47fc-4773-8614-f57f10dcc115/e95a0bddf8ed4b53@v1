async function getTenantAccessToken() {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/auth/v3/tenant_access_token/internal`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      app_id: feishuConfig.appId,
      app_secret: feishuConfig.appSecret
    })
  });
  const data = await response.json();
  return data.tenant_access_token;
}

async function writeRange(token, range, values) {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v2/spreadsheets/${feishuConfig.spreadsheetToken}/values`, {
    method: 'PUT',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      valueRange: {
        range: range,
        values: values
      }
    })
  });

  const text = await response.text();
  try {
    return JSON.parse(text);
  } catch {
    return { code: -1, msg: 'Invalid JSON response', raw: text };
  }
}

async function writeBatchData(token) {
  const results = [];

  // Write feature data (Sheet 0)
  console.log('📊 写入产品特性数据...');

  // Header
  results.push(await writeRange(token, "产品特性分析!A1", [[
    "产品特性", "产品数量占比", "月销量占比", "说明"
  ]]));

  // Data rows
  for (const f of productData.features) {
    results.push(await writeRange(token, "产品特性分析!A2:D2", [[
      f.feature, f.productRatio, f.salesRatio, f.description
    ]]));
  }

  // Write hot products data (Sheet 1)
  console.log('🔥 写入热销产品数据...');

  // Header
  results.push(await writeRange(token, "热销产品榜单!A1", [[
    "排名", "品牌", "价格", "月销量", "特点"
  ]]));

  // Data rows
  for (const p of productData.hotProducts) {
    results.push(await writeRange(token, "热销产品榜单!A2:E2", [[
      p.rank, p.brand, p.price, p.monthlySales, p.feature
    ]]));
  }

  // Write summary data
  console.log('📈 写入汇总数据...');
  const summaryData = [
    ["关键词", "A4 Portable Thermal Printer"],
    ["市场", "Amazon US"],
    ["数据来源", "Sorftime"],
    ["更新时间", new Date().toLocaleString('zh-CN')],
    [""],
    ["统计指标", "数值"],
    ["分析产品数", "46"],
    ["特性数量", productData.features.length],
    ["热销产品数", productData.hotProducts.length],
    [""],
    ["价格区间", "$27.99 - $79.99"],
    ["总月销量", "49199"],
    ["平均价格", "$52.70"],
    ["最高销量", "16883"]
  ];

  for (const row of summaryData) {
    results.push(await writeRange(token, "市场数据汇总!A1:B1", [row]));
  }

  return results;
}

