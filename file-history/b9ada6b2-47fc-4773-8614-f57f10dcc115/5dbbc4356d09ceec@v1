async function getTenantAccessToken() {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/auth/v3/tenant_access_token/internal`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      app_id: feishuConfig.appId,
      app_secret: feishuConfig.appSecret
    })
  });
  const data = await response.json();
  return data.tenant_access_token;
}

async function getSpreadsheetSheets(token) {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v3/spreadsheets/${feishuConfig.spreadsheetToken}/sheets/query`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    }
  });
  return await response.json();
}

async function appendRow(token, sheetId, values) {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v2/spreadsheets/${feishuConfig.spreadsheetToken}/sheets/${sheetId}/rows`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      rows: [{
        values: values.map(v => ({ v: v }))
      }]
    })
  });
  return await response.json();
}

async function updateCells(token, sheetId, startRow, startColumn, values) {
  // Calculate end column based on data
  const maxCols = Math.max(...values.map(row => row.length));
  const endColumn = startColumn + maxCols - 1;
  const endRow = startRow + values.length - 1;

  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v2/spreadsheets/${feishuConfig.spreadsheetToken}/sheets/${sheetId}/cells/${startRow}_${startColumn}/${endRow}_${endColumn}`, {
    method: 'PUT',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      value: {
        values: values.map(row => row.map(v => ({ v: v })))
      }
    })
  });
  return await response.json();
}

async function writeDataToSheets(token) {
  // Get sheet info
  console.log('📊 获取表格信息...');
  const sheetsInfo = await getSpreadsheetSheets(token);
  console.log('Sheets info:', JSON.stringify(sheetsInfo, null, 2));

  if (sheetsInfo.code !== 0) {
    throw new Error(`Failed to get sheets: ${sheetsInfo.msg}`);
  }

  const sheets = sheetsInfo.data.sheet_items || sheetsInfo.data.sheets || [];
  console.log(`找到 ${sheets.length} 个工作表`);

  const results = [];

  // Write feature data to first sheet
  if (sheets.length > 0) {
    const sheetId = sheets[0].sheet_id;
    console.log(`\n📝 写入产品特性数据到 Sheet ${sheetId}...`);

    const featureValues = [
      ["产品特性", "产品数量占比", "月销量占比", "说明"],
      ...productData.features.map(f => [f.feature, f.productRatio, f.salesRatio, f.description])
    ];

    try {
      const result = await updateCells(token, sheetId, 1, 1, featureValues);
      console.log('✅ 产品特性数据写入结果:', result.code === 0 ? '成功' : result.msg);
      results.push({ sheet: '产品特性', success: result.code === 0 });
    } catch (e) {
      console.log('❌ 写入失败:', e.message);
      results.push({ sheet: '产品特性', success: false, error: e.message });
    }
  }

  // Create new sheet for products
  console.log('\n📄 创建热销产品工作表...');
  const addSheetResponse = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v3/spreadsheets/${feishuConfig.spreadsheetToken}/sheets`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      title: "热销产品榜单",
      sheet_type: "grid"
    })
  });
  const addSheetResult = await addSheetResponse.json();
  console.log('Add sheet result:', JSON.stringify(addSheetResult, null, 2));

  if (addSheetResult.code === 0) {
    const productSheetId = addSheetResult.data.sheet.sheet_id;
    console.log(`✅ 新工作表创建成功: ${productSheetId}`);

    const productValues = [
      ["排名", "品牌", "价格", "月销量", "特点"],
      ...productData.hotProducts.map(p => [p.rank, p.brand, p.price, p.monthlySales, p.feature])
    ];

    try {
      const result = await updateCells(token, productSheetId, 1, 1, productValues);
      console.log('✅ 热销产品数据写入结果:', result.code === 0 ? '成功' : result.msg);
      results.push({ sheet: '热销产品', success: result.code === 0 });
    } catch (e) {
      console.log('❌ 写入失败:', e.message);
      results.push({ sheet: '热销产品', success: false, error: e.message });
    }
  }

  return results;
}

