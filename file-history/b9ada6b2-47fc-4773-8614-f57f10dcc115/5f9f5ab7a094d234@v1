  endpoint: "https://open.feishu.cn"
};

async function getTenantAccessToken() {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/auth/v3/tenant_access_token/internal`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      app_id: feishuConfig.appId,
      app_secret: feishuConfig.appSecret
    })
  });
  const data = await response.json();
  if (data.code !== 0) {
    throw new Error(`Failed: ${data.msg}`);
  }
  return data.tenant_access_token;
}

async function getAppPermissions(token) {
  // Try to get app info to see current permissions
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/application/v6/applications/app_info`, {
    method: 'GET',
    headers: {
      'Authorization': `Bearer ${token}`
    }
  });
  const text = await response.text();
  console.log('App info response:', text);
  try {
    return JSON.parse(text);
  } catch {
    return { code: -1, msg: 'Invalid JSON', raw: text };
  }
}

async function testWritePermission(token, spreadsheetToken) {
  // Test write permission
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v2/spreadsheets/${spreadsheetToken}/sheets/0/rows`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      rows: [{
        values: [{ v: "测试" }, { v: "数据" }]
      }]
    })
  });
  const text = await response.text();
  console.log('Test write response:', text);
  try {
    return JSON.parse(text);
  } catch {
    return { code: -1, msg: 'Invalid JSON', raw: text };
  }
}

async function createAndWrite() {
  // Create new spreadsheet and try to write immediately
  const token = await getTenantAccessToken();

  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v3/spreadsheets`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      title: `测试表格-${Date.now()}`
    })
  });
  const data = await response.json();

  console.log('Create result:', JSON.stringify(data, null, 2));

  if (data.code === 0) {
    const spreadsheetToken = data.data.spreadsheet.spreadsheet_token;
    const url = data.data.spreadsheet.url;

    console.log('\n✅ 测试表格创建成功!');
    console.log('Token:', spreadsheetToken);
    console.log('URL:', url);

    // Try to write data immediately
    console.log('\n📝 测试写入数据...');
    const testResult = await testWritePermission(token, spreadsheetToken);

    return { success: testResult.code === 0, spreadsheetToken, url, error: testResult.msg };
  }

  return { success: false, error: data.msg };
}

