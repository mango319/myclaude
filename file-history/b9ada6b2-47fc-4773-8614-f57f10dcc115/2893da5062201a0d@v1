async function getTenantAccessToken() {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/auth/v3/tenant_access_token/internal`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      app_id: feishuConfig.appId,
      app_secret: feishuConfig.appSecret
    })
  });
  const data = await response.json();
  if (data.code !== 0) {
    throw new Error(`Failed to get token: ${data.msg}`);
  }
  return data.tenant_access_token;
}

async function createSpreadsheet(token) {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v3/spreadsheets`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      title: `Amazon产品分析-${productData.keyword}-${Date.now()}`,
      folder_token: ""  // Create in root folder
    })
  });

  const data = await response.json();
  console.log('Create spreadsheet response:', JSON.stringify(data, null, 2));

  if (data.code !== 0) {
    throw new Error(`Failed to create spreadsheet: ${data.msg}`);
  }

  return {
    spreadsheetToken: data.data.spreadsheet.spreadsheet_token,
    url: data.data.spreadsheet.url
  };
}

async function addSheetData(token, spreadsheetToken) {
  // Get spreadsheet info to find sheet IDs
  const infoResponse = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v3/spreadsheets/${spreadsheetToken}`, {
    method: 'GET',
    headers: {
      'Authorization': `Bearer ${token}`
    }
  });

  const info = await infoResponse.json();
  console.log('Spreadsheet info:', JSON.stringify(info, null, 2));

  if (info.code === 0 && info.data.spreadsheet.sheets) {
    const sheetId = info.data.spreadsheet.sheets[0].sheet_id;
    console.log('Using sheet ID:', sheetId);

    // Write feature data
    const featureValues = [
      ["产品特性", "产品数量占比", "月销量占比", "说明"],
      ...productData.features.map(f => [f.feature, f.productRatio, f.salesRatio, f.description])
    ];

    // Write hot products data
    const productValues = [
      ["排名", "品牌", "价格", "月销量", "特点"],
      ...productData.hotProducts.map(p => [p.rank, p.brand, p.price, p.monthlySales, p.feature])
    ];

    console.log('Feature values:', featureValues.length, 'rows');
    console.log('Product values:', productValues.length, 'rows');

    return { sheetId, featureValues, productValues };
  }

  throw new Error('Failed to get spreadsheet info');
}

