async function getTenantAccessToken() {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/auth/v3/tenant_access_token/internal`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      app_id: feishuConfig.appId,
      app_secret: feishuConfig.appSecret
    })
  });
  const data = await response.json();
  return data.tenant_access_token;
}

async function createSpreadsheet(token) {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v3/spreadsheets`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      title: `Temu-A4热敏打印机分析-${Date.now()}`,
      folder_token: ""
    })
  });
  const data = await response.json();
  if (data.code !== 0) {
    throw new Error(`Failed to create spreadsheet: ${data.msg}`);
  }
  return {
    spreadsheetToken: data.data.spreadsheet.spreadsheet_token,
    url: data.data.spreadsheet.url
  };
}

async function getSheetId(token, spreadsheetToken) {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v3/spreadsheets/${spreadsheetToken}/sheets/query`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    }
  });
  const data = await response.json();
  if (data.code === 0 && data.data.sheet_items && data.data.sheet_items.length > 0) {
    return data.data.sheet_items[0].sheet_id;
  }
  throw new Error('Failed to get sheet ID');
}

