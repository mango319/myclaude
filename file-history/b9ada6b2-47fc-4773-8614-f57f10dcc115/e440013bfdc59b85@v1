async function addSecondSheet(token, spreadsheetToken) {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v3/spreadsheets/${spreadsheetToken}/sheets`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      title: "产品特性分析",
      sheet_type: "grid"
    })
  });
  const data = await response.json();
  if (data.code === 0) {
    return data.data.sheet.sheet_id;
  }
  throw new Error('Failed to add sheet');
}

