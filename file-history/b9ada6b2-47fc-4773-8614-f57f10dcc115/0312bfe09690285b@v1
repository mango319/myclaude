async function getTenantAccessToken() {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/auth/v3/tenant_access_token/internal`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      app_id: feishuConfig.appId,
      app_secret: feishuConfig.appSecret
    })
  });
  const data = await response.json();
  return data.tenant_access_token;
}

async function createNewSpreadsheet(token) {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v3/spreadsheets`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      title: `Temu热敏打印机-${Date.now()}`
    })
  });

  const data = await response.json();
  console.log('Create response:', JSON.stringify(data, null, 2));

  if (data.code !== 0) {
    throw new Error(`Failed: ${data.msg}`);
  }

  return {
    token: data.data.spreadsheet.spreadsheet_token,
    url: data.data.spreadsheet.url,
    title: data.data.spreadsheet.title
  };
}

async function createFeishuDoc(token) {
  // Try creating a document instead
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/docx/v1/documents`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      title: `Temu热敏打印机分析-${Date.now()}`,
      folder_token: ""
    })
  });

  const data = await response.json();
  console.log('Create doc response:', JSON.stringify(data, null, 2));

  if (data.code === 0) {
    return {
      token: data.data.document.document_id,
      url: data.data.document.url,
      title: data.data.document.title
    };
  }

  throw new Error(`Failed: ${data.msg}`);
}

