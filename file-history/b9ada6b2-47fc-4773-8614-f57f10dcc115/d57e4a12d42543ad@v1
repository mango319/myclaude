async function getTenantAccessToken() {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/auth/v3/tenant_access_token/internal`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      app_id: feishuConfig.appId,
      app_secret: feishuConfig.appSecret
    })
  });
  const data = await response.json();
  if (data.code !== 0) {
    throw new Error(`Failed to get token: ${data.msg}`);
  }
  return data.tenant_access_token;
}

async function getSpreadsheetInfo(token) {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v3/spreadsheets/${feishuConfig.spreadsheetToken}`, {
    method: 'GET',
    headers: { 'Authorization': `Bearer ${token}` }
  });
  const text = await response.text();
  console.log('Get spreadsheet info:', text);
  try {
    return JSON.parse(text);
  } catch {
    return { code: -1, msg: 'Invalid JSON', raw: text };
  }
}

async function appendRows(token, sheetId, rows) {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v2/spreadsheets/${feishuConfig.spreadsheetToken}/sheets/${sheetId}/rows`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      rows: rows.map(row => ({
        values: row.map(v => ({ v: v }))
      }))
    })
  });
  const text = await response.text();
  console.log('Append rows response:', text);
  try {
    return JSON.parse(text);
  } catch {
    return { code: -1, msg: 'Invalid JSON', raw: text };
  }
}

async function addNewSheet(token, title) {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v3/spreadsheets/${feishuConfig.spreadsheetToken}/sheets`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      title: title,
      sheet_type: "grid"
    })
  });
  const text = await response.text();
  console.log('Add sheet response:', text);
  try {
    const data = JSON.parse(text);
    if (data.code === 0) {
      return data.data.sheet.sheet_id;
    }
    throw new Error(data.msg);
  } catch {
    throw new Error(text);
  }
}

