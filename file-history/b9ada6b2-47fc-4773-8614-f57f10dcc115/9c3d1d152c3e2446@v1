async function getTenantAccessToken() {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/auth/v3/tenant_access_token/internal`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      app_id: feishuConfig.appId,
      app_secret: feishuConfig.appSecret
    })
  });
  const data = await response.json();
  return data.tenant_access_token;
}

async function createSpreadsheet(token) {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v3/spreadsheets`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      title: `Temu-A4热敏打印机分析-${new Date().toISOString().slice(0,10)}`,
      folder_token: ""
    })
  });
  const data = await response.json();
  console.log('Create spreadsheet response:', JSON.stringify(data, null, 2));

  if (data.code !== 0) {
    throw new Error(`Failed to create spreadsheet: ${data.msg}`);
  }
  return {
    spreadsheetToken: data.data.spreadsheet.spreadsheet_token,
    url: data.data.spreadsheet.url
  };
}

async function getSpreadsheetInfo(token, spreadsheetToken) {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v3/spreadsheets/${spreadsheetToken}`, {
    method: 'GET',
    headers: {
      'Authorization': `Bearer ${token}`
    }
  });

  const text = await response.text();
  console.log('Spreadsheet info response:', text);

  try {
    return JSON.parse(text);
  } catch {
    return { code: -1, msg: 'Invalid JSON', raw: text };
  }
}

async function addRows(token, spreadsheetToken, sheetId, rows) {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v2/spreadsheets/${spreadsheetToken}/sheets/${sheetId}/rows`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      rows: rows.map(row => ({
        values: row.map(v => ({ v: v }))
      }))
    })
  });

  const text = await response.text();
  console.log('Add rows response:', text);

  try {
    return JSON.parse(text);
  } catch {
    return { code: -1, msg: 'Invalid JSON', raw: text };
  }
}

async function addSheet(token, spreadsheetToken, title) {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v3/spreadsheets/${spreadsheetToken}/sheets`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      title: title,
      sheet_type: "grid"
    })
  });

  const text = await response.text();
  console.log('Add sheet response:', text);

  try {
    const data = JSON.parse(text);
    if (data.code === 0) {
      return data.data.sheet.sheet_id;
    }
    throw new Error(`Failed to add sheet: ${data.msg}`);
  } catch {
    throw new Error(`Failed to add sheet: ${text}`);
  }
}

