async function getTenantAccessToken() {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/auth/v3/tenant_access_token/internal`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      app_id: feishuConfig.appId,
      app_secret: feishuConfig.appSecret
    })
  });
  const data = await response.json();
  return data.tenant_access_token;
}

async function appendData(token) {
  const rows = [
    ["排名", "型号", "价格($)", "评分", "评价数", "主要特点"],
    ...temuData.products.map(p => [p.rank, p.model, p.price, p.rating, p.reviews, p.features]),
    [""],
    ["📊 Temu vs 亚马逊", "", "", "", "", ""],
    ["平台", "平均价格($)", "", "", "", ""],
    ["Temu", 24.29, "", "", "", ""],
    ["亚马逊", 52.70, "", "", "", ""],
    ["价格差异", "-54%", "", "", "", ""],
    [""],
    ["🌟 关键发现", "", "", "", "", ""],
    ["• Temu 更便宜", "54%", "", "", "", ""],
    ["• 热销型号", "M832 Pro", "", "", "", ""]
  ];

  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v2/spreadsheets/${feishuConfig.spreadsheetToken}/sheets/0/rows`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      rows: rows.map(row => ({
        values: row.map(v => ({ v: v }))
      }))
    })
  });

  const text = await response.text();
  console.log('Append data response:', text);

  try {
    const data = JSON.parse(text);
    return data.code === 0;
  } catch {
    return false;
  }
}

