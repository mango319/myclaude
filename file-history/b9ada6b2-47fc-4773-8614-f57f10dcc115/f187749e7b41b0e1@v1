      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      title: "产品特性分析",
      sheet_type: "grid"
    })
  });
  const data = await response.json();
  console.log('Add sheet response:', JSON.stringify(data, null, 2));

  if (data.code === 0) {
    const featureSheetId = data.data.sheet.sheet_id;
    console.log('Feature sheet created:', featureSheetId);

    // Write feature data
    const featureRows = [
      ...temuData.features,
      [""],
      ["📈 Temu 市场特点", "", ""],
