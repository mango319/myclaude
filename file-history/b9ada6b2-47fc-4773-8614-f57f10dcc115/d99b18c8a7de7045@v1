async function getTenantAccessToken() {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/auth/v3/tenant_access_token/internal`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      app_id: feishuConfig.appId,
      app_secret: feishuConfig.appSecret
    })
  });
  const data = await response.json();
  return data.tenant_access_token;
}

async function batchUpdateValues(token, spreadsheetToken, updates) {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v2/spreadsheets/${spreadsheetToken}/values:batchUpdate`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      valueRanges: updates
    })
  });
  const text = await response.text();
  console.log('Batch update response:', text);
  try {
    return JSON.parse(text);
  } catch {
    return { code: -1, msg: 'Invalid JSON', raw: text };
  }
}

async function createAndPopulate() {
  const token = await getTenantAccessToken();

  // Create new spreadsheet
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v3/spreadsheets`, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      title: `Temu热敏打印机-${new Date().toISOString().slice(0,10)}`
    })
  });
  const data = await response.json();

  if (data.code !== 0) {
    throw new Error(data.msg);
  }

  const spreadsheetToken = data.data.spreadsheet.spreadsheet_token;
  const url = data.data.spreadsheet.url;
  const sheetId = data.data.spreadsheet.sheets[0].sheet_id;

  console.log('✅ 表格创建成功!');
  console.log('Token:', spreadsheetToken);
  console.log('Sheet ID:', sheetId);
  console.log('URL:', url);

  // Try to write using the sheet_id directly
  console.log('\n📝 尝试方法1: 使用 appendRows API...');
  try {
    const appendResponse = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v2/spreadsheets/${spreadsheetToken}/sheets/${sheetId}/rows`, {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${token}`,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        rows: temuData.map(row => ({
          values: row.map(v => ({ v: v }))
        }))
      })
    });
    const appendText = await appendResponse.text();
    console.log('Append result:', appendText);
    if (appendText.includes('"code":0')) {
      console.log('✅ 方法1成功!');
      return { success: true, url };
    }
  } catch (e) {
    console.log('方法1失败:', e.message);
  }

  console.log('\n📝 尝试方法2: 使用 batchUpdate API...');
  try {
    const updates = temuData.map((row, i) => ({
      range: `Sheet1!A${i + 1}`,
      values: [row]
    }));
    const batchResult = await batchUpdateValues(token, spreadsheetToken, updates);
    if (batchResult.code === 0) {
      console.log('✅ 方法2成功!');
      return { success: true, url };
    }
  } catch (e) {
    console.log('方法2失败:', e.message);
  }

  console.log('\n📝 尝试方法3: 逐个单元格写入...');
  for (let r = 0; r < Math.min(5, temuData.length); r++) {
    for (let c = 0; c < temuData[r].length; c++) {
      try {
        const cellResponse = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v2/spreadsheets/${spreadsheetToken}/values`, {
          method: 'PUT',
          headers: {
            'Authorization': `Bearer ${token}`,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            valueRange: {
              range: `Sheet1!${String.fromCharCode(65 + c)}${r + 1}`,
              values: [[temuData[r][c]]]
            }
          })
        });
        const cellText = await cellResponse.text();
        if (cellText.includes('"code":0')) {
          console.log(`  ✅ Cell ${String.fromCharCode(65 + c)}${r + 1} written`);
        }
      } catch (e) {
        // Ignore individual cell failures
      }
    }
  }

  return { success: false, url, error: 'All methods failed' };
}

