async function getTenantAccessToken() {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/auth/v3/tenant_access_token/internal`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      app_id: feishuConfig.appId,
      app_secret: feishuConfig.appSecret
    })
  });
  const data = await response.json();
  return data.tenant_access_token;
}

async function batchUpdateCells(token, sheetId, ranges, values) {
  const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v2/spreadsheets/${feishuConfig.spreadsheetToken}/values`, {
    method: 'PUT',
    headers: {
      'Authorization': `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      valueRange: {
        range: ranges,
        values: values
      }
    })
  });
  const text = await response.text();
  console.log(`Update cells ${ranges}:`, text);
  try {
    return JSON.parse(text);
  } catch {
    return { code: -1, msg: 'Invalid JSON', raw: text };
  }
}

async function updateCellByCell(token, sheetId, rows) {
  const results = [];
  for (let r = 0; r < rows.length; r++) {
    for (let c = 0; c < rows[r].length; c++) {
      const range = `${sheetId}!${String.fromCharCode(65 + c)}${r + 1}`;
      const response = await fetch(`${feishuConfig.endpoint}/open-apis/sheets/v2/spreadsheets/${feishuConfig.spreadsheetToken}/values`, {
        method: 'PUT',
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          valueRange: {
            range: range,
            values: [[rows[r][c]]]
          }
        })
      });
      const text = await response.text();
      try {
        const data = JSON.parse(text);
        results.push({ range, success: data.code === 0 });
        if (data.code !== 0) {
          console.log(`Failed to write ${range}:`, data.msg);
        }
      } catch {
        results.push({ range, success: false, error: text });
      }
    }
  }
  return results;
}

