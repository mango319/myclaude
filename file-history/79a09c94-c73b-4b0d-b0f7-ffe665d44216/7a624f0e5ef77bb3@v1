      new Paragraph({ children: [new TextRun({ text: '# 平台适配器接口定义\n\nclass PlatformAdapter(ABC):\n    """平台适配器基类"""\n    \n    @abstractmethod\n    async def receive_message(self, data: dict) -> Message:\n        """接收平台消息"""\n        pass\n    \n    @abstractmethod\n    async def send_message(self, user_id: str, content: str, **kwargs) -> dict:\n        """发送消息到平台"""\n        pass\n    \n    @abstractmethod\n    def get_platform_name(self) -> str:\n        """获取平台名称"""\n        pass\n\n# 实现示例：天猫适配器\n\nclass TmallAdapter(PlatformAdapter):\n    """天猫平台适配器"""\n    \n    def __init__(self, app_key: str, app_secret: str):\n        self.app_key = app_key\n        self.app_secret = app_secret\n        self.client = TmallClient(app_key, app_secret)\n    \n    async def receive_message(self, data: dict) -> Message:\n        # 解析天猫消息格式\n        user_id = data[\'from_user\']\n        content = data[\'content\']\n        message_id = data[\'message_id\']\n        \n        return Message(\n            platform=\'tmall\',\n            user_id=user_id,\n            content=content,\n            message_id=message_id,\n            raw_data=data\n        )\n    \n    async def send_message(self, user_id: str, content: str, **kwargs) -> dict:\n        # 发送消息到天猫\n        return await self.client.send(user_id, content)\n    \n    def get_platform_name(self) -> str:\n        return "天猫"', font: 'Courier New', size: 18 })] }),

