# 健康检查
@app.get("/health", tags=["Health"])
async def health_check():
    """健康检查"""
    health_status = {
        "status": "healthy",
        "version": settings.APP_VERSION,
        "timestamp": logger._core.start_time
    }

    # 检查各服务状态
    services = {}

    # 检查Redis
    if hasattr(app.state, "redis") and app.state.redis:
        try:
            await app.state.redis.ping()
            services["redis"] = "healthy"
        except Exception:
            services["redis"] = "unhealthy"
            health_status["status"] = "degraded"
    else:
        services["redis"] = "not configured"

    # 检查知识库
    try:
        from services import kb_service
        if kb_service._initialized:
            services["knowledge_base"] = "healthy"
        else:
            services["knowledge_base"] = "initializing"
            health_status["status"] = "degraded"
    except Exception:
        services["knowledge_base"] = "error"
        health_status["status"] = "degraded"

    # 检查平台连接
    try:
        from gateway.router import router
        platform_health = await router.health_check_all()
        for platform, healthy in platform_health.items():
            services[f"platform_{platform.value}"] = "healthy" if healthy else "unhealthy"

            if not healthy and health_status["status"] == "healthy":
                health_status["status"] = "degraded"
    except Exception:
        services["platforms"] = "error"

    health_status["services"] = services

    return health_status


# 指标端点（Prometheus）
@app.get("/metrics", tags=["Monitoring"])
async def metrics():
    """Prometheus指标"""
    if not settings.ENABLE_METRICS:
        return {"error": "Metrics disabled"}

    from prometheus_client import generate_latest, CONTENT_TYPE_LATEST
    from fastapi.responses import Response

    return Response(
        content=generate_latest(),
        media_type=CONTENT_TYPE_LATEST
    )


