async function importProducts() {
  for (let i = 0; i < filteredProducts.length; i++) {
    const product = filteredProducts[i];
    const jsonStr = JSON.stringify(product);

    const cmd = `lark-cli base +record-upsert --base-token "${baseToken}" --table-id "${tableId}" --json '${jsonStr}'`;

    try {
      console.log(`导入产品 ${i + 1}/${filteredProducts.length}: ${product["产品ASIN码"]}`);
      execSync(cmd, { stdio: 'inherit' });
      await new Promise(resolve => setTimeout(resolve, 500));
    } catch (error) {
      console.error(`导入失败: ${product["产品ASIN码"]}`, error.message);
    }
  }

  console.log('所有产品导入完成!');
}

importProducts();
