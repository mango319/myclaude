const baseToken = "YDBhbylY3aPh7bs3GAXcchZtn7f";
const tableId = "tblAcpskf76cChax";
const tempDir = path.join(__dirname, 'temp_json');
if (!fs.existsSync(tempDir)) {
  fs.mkdirSync(tempDir);
}

async function importProducts() {
  for (let i = 0; i < products.length; i++) {
    const product = products[i];
    const tempFile = path.join(tempDir, `product_${i}.json`);
    fs.writeFileSync(tempFile, JSON.stringify(product, null, 2));

    const cmd = `lark-cli base +record-upsert --base-token "${baseToken}" --table-id "${tableId}" --json @${tempFile}`;

    try {
      console.log(`导入产品 ${i + 1}/${products.length}: ${product["产品ASIN码"]}`);
      execSync(cmd, { stdio: 'inherit' });
      // 延迟0.5秒避免并发冲突
      await new Promise(resolve => setTimeout(resolve, 500));
    } catch (error) {
      console.error(`导入失败: ${product["产品ASIN码"]}`, error.message);
    }
  }

  // 清理临时文件
  fs.rmSync(tempDir, { recursive: true, force: true });
  console.log('所有产品导入完成!');
}

importProducts();
